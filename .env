# 各部分功能开关
# 基本AI交互开
SWITCH__CALL_AI_IS_ENABLE=True
# 图片处理开关
SWITCH__IMAGE_HANDLE_IS_ENABLE=True
# 记忆功能开关
SWITCH__MEMORY_HANDLE_IS_ENABLE=True
# 声音处理开关
SWITCH__VOICE_HANDLE_IS_ENABLE=True

# openAI 各参数
OPENAI__API_URL=https://api.siliconflow.cn/v1
OPENAI__API_KEY=

# baiduAI 各参数
BAIDU__REPORT_URL=https://aip.baidubce.com/rest/2.0/image-classify/v1/image-understanding/request
BAIDU__GET_RESULT_URL=https://aip.baidubce.com/rest/2.0/image-classify/v1/image-understanding/get-result
BAIDU__API_KEY=
BAIDU__SECRET_KEY=
BAIDU__TOKEN_URL=https://aip.baidubce.com/oauth/2.0/token

# 记忆相似度阈值
MEMORY__THRESHOLD=0.42